# LMStudio API
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_API_KEY=lm-studio

# Model names (LMStudio'da yüklü model isimleri)
OCR_MODEL_NAME=chandra-ocr-2
EMBEDDING_MODEL_NAME=text-embedding-bge-m3
QA_MODEL_NAME=nemotron-3-nano

# OCR settings
OCR_MAX_TOKENS=12384

# App settings
APP_HOST=0.0.0.0
APP_PORT=8000
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs

# Database
SQLITE_DB_PATH=dokuman_analiz.db
CHROMA_DB_PATH=chroma_data

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
